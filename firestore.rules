rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: matches
    // Document ID: matchId
    // Fields:
    //   - id: string (required)
    //   - sport: string (required)
    //   - homeTeam: string (required)
    //   - awayTeam: string (required)
    //   - homeScore: number (required)
    //   - awayScore: number (required)
    //   - status: string (required, enum: live, scheduled, finished)
    //   - time: string (required)
    //   - events: list (optional)
    //   - prediction: string (optional)
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, enum: admin, user)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "phring073@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidMatch(data) {
      return data.id is string &&
             data.sport is string &&
             data.homeTeam is string &&
             data.awayTeam is string &&
             data.homeScore is number &&
             data.awayScore is number &&
             data.status in ['live', 'scheduled', 'finished'] &&
             data.time is string;
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }

    match /matches/{matchId} {
      allow read: if true; // Publicly readable for live scores
      allow write: if isAdmin(); // Only admins (or the server-side logic) can write
    }
  }
}
